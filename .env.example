# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# PostgreSQL
POSTGRES_USER=medallion
POSTGRES_PASSWORD=medallion
POSTGRES_DB=medallion
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Pipeline settings
RAW_DATA_PATH=data/raw_tickets.csv
LOG_LEVEL=INFO

# Agent settings
# Max rows to send to LLM for profiling/schema inference (keep low to control cost)
AGENT_SAMPLE_SIZE=50
# Max rows per batch for semantic classification
SEMANTIC_BATCH_SIZE=20